library IEEE;
use IEEE.STD_LOGIC_1164.ALL;

entity D_FF is
    Port (
        D   : in  STD_LOGIC;
        CLK : in  STD_LOGIC;
        Q   : out STD_LOGIC
    );
end D_FF;

architecture Behavioral of D_FF is
    signal q_reg : STD_LOGIC := '0';
begin
    process(CLK)
    begin
        if rising_edge(CLK) then
            q_reg <= D;
        end if;
    end process;

    Q <= q_reg;
end Behavioral;
