library IEEE;
use IEEE.STD_LOGIC_1164.ALL;

entity D_FF_dataflow is
    Port (
        D   : in  STD_LOGIC;
        CLK : in  STD_LOGIC;
        Q   : out STD_LOGIC;
        Qn  : out STD_LOGIC
    );
end D_FF_dataflow;

architecture Dataflow of D_FF_dataflow is
    signal Dn : STD_LOGIC;
    signal CLKn : STD_LOGIC;

    -- master latch signals
    signal Sm, Rm : STD_LOGIC;
    signal Qm, Qmn : STD_LOGIC;

    -- slave latch signals
    signal Ss, Rs : STD_LOGIC;
    signal Qs, Qsn : STD_LOGIC;

begin
    Dn   <= not D;
    CLKn <= not CLK;

    -- Master latch (active when CLK = '1')
    Sm  <= not (D  and CLK);
    Rm  <= not (Dn and CLK);
    Qm  <= not (Sm and Qmn);
    Qmn <= not (Rm and Qm);

    -- Slave latch (active when CLK = '0')
    Ss  <= not (Qm  and CLKn);
    Rs  <= not (Qmn and CLKn);
    Qs  <= not (Ss and Qsn);
    Qsn <= not (Rs and Qs);

    Q  <= Qs;
    Qn <= Qsn;

end Dataflow;
