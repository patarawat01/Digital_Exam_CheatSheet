library IEEE;
use IEEE.STD_LOGIC_1164.ALL;

entity clk_div2_behavioral is
    Port (
        CLK_IN  : in  STD_LOGIC;
        CLK_OUT : out STD_LOGIC
    );
end clk_div2_behavioral;

architecture Behavioral of clk_div2_behavioral is
    signal temp : STD_LOGIC := '0';
begin
    process(CLK_IN)
    begin
        if rising_edge(CLK_IN) then
            temp <= not temp;
        end if;
    end process;

    CLK_OUT <= temp;
end Behavioral;
