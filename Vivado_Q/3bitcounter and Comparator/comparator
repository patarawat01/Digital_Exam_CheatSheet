library IEEE;
use IEEE.STD_LOGIC_1164.ALL;

entity comparator3 is
    port (
        A : in std_logic_vector(2 downto 0);
        B : in std_logic_vector(2 downto 0);
        equal : out std_logic
    );
end comparator3;

architecture Dataflow of comparator3 is
begin
    -- LED is '1' only when bits match exactly
    equal <= '1' when (A = B) else '0';
end Dataflow;
