library IEEE;
use IEEE.STD_LOGIC_1164.ALL;

entity tb_counter_comp_system is
end tb_counter_comp_system;

architecture Behavioral of tb_counter_comp_system is
    -- Signals
    signal clk_tb       : std_logic := '0';
    signal reset_tb     : std_logic := '0';
    signal sw_input_tb  : std_logic_vector(2 downto 0) := "011"; -- Targeting '3'
    signal match_led_tb : std_logic;

    -- Clock period definition
    constant clk_period : time := 10 ns;
begin

    -- Instantiate the Top Module
    UUT: entity work.counter_comp_top
        port map (
            clk => clk_tb,
            reset => reset_tb,
            sw_input => sw_input_tb,
            match_led => match_led_tb
        );

    -- Clock generation
    clk_process : process
    begin
        clk_tb <= '0';
        wait for clk_period/2;
        clk_tb <= '1';
        wait for clk_period/2;
    end process;

    -- Stimulus process
    stim_proc: process
    begin		
        -- Reset the system
        reset_tb <= '1';
        wait for 20 ns;	
        reset_tb <= '0';

        -- Wait and observe the match_led in the waveform
        -- Since there is a clock divider, you'll need to simulate 
        -- long enough to see the divided clock toggle.
        wait for 2 ms; 

        -- Change switches to target '5'
        sw_input_tb <= "101";
        wait for 2 ms;

        wait;
    end process;

end Behavioral;
