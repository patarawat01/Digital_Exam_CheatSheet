library IEEE;
use IEEE.STD_LOGIC_1164.ALL;

entity tb_counter3_jk is
end c;

architecture Behavioral of tb_counter3_jk is
    signal clk_tb   : std_logic := '0';
    signal reset_tb : std_logic := '0';
    signal Q_tb     : std_logic_vector(2 downto 0);

    constant clk_period : time := 10 ns;
begin
    -- Instantiate the Counter
    UUT: entity work.counter3_jk 
        port map(clk => clk_tb, reset => reset_tb, Q => Q_tb);

    -- Clock Generation
    clk_process : process
    begin
        clk_tb <= '0'; wait for clk_period/2;
        clk_tb <= '1'; wait for clk_period/2;
    end process;

    -- Stimulus
    stim_proc: process
    begin
        reset_tb <= '1'; wait for 20 ns;
        reset_tb <= '0'; 
        
        -- Run long enough to see 0 to 7 twice
        wait for 200 ns;
        
        -- Test reset mid-count
        reset_tb <= '1'; wait for 10 ns;
        reset_tb <= '0';
        
        wait;
    end process;
end Behavioral;
